class Solution(object):
    def makeGood(self, s):
       
      
     stack = []
     for i in range(len(s)):
        if not stack:
            stack.append(s[i])
        elif abs(ord(stack[-1]) - ord(s[i])) == 32:
            stack.pop()
        else:
            stack.append(s[i])
        
        
    
     return "".join(stack)
        
