class Solution(object):
    def findThePrefixCommonArray(self, A, B):

       result =[] 
       a =[]
       b =[]
       for i in range(0,len(A)):
         a.append(A[i])
         b.append(B[i])

         count =0
         for i in a:
            if i in b:
                count+=1
         result.append(count)    
       return result     
                





        
