class Solution(object):
    def kidsWithCandies(self, candies, extraCandies):
        max_candies = max(candies)
        result = []
        B = 0
        for i in candies:
            B = i+extraCandies
            if B>=max_candies:
                result.append(True)
            else:
                result.append(False) 
        return result        
