class Solution(object):
    def nextGreaterElement(self, nums1, nums2):
       
     for i in range(len(nums1)):
    
        if nums1[i] in nums2:
            k = nums1[i]
            j = nums2.index(k)
            found = -1
            for x in range(j+1,len(nums2)):
                if k< nums2[x]:
                    found = nums2[x]
                    break
            nums1[i] = found
        
     return nums1           

        
