#User function Template for python3
class Solution:
    def subarraySum(self, arr, target):
        l =0
        cur_sum = 0
        for r in range(len(arr)):
            cur_sum += arr[r]
            while cur_sum > target:
                cur_sum -= arr[l]
                l+=1
            if cur_sum ==target:
                return(l+1,r+1)
        return[-1]
