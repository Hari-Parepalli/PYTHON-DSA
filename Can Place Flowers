class Solution(object):
    def canPlaceFlowers(self, flowerbed, n):
     

     m = len(flowerbed)
     for i in range(m):
         if flowerbed[i] == 0:
             left = (i == 0) or (flowerbed[i-1] == 0)   
             right = (i == len(flowerbed) - 1) or (flowerbed[i+1] == 0)   
             if left and right:
                 flowerbed[i] = 1
                 n -=1
     return True if n <= 0 else False
                
