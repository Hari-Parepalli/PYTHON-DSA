class Solution(object):
    def findDifference(self, nums1, nums2):
     list1 = []
     list2 = []
     num_1 = set(nums1)
     num_2 = set(nums2)
     for i in num_1:
         if i not in num_2:
             list1.append(i)
     for j in num_2:
         if j not in num_1:
             list2.append(j)
     answer = [list1,list2]        
     return answer  
