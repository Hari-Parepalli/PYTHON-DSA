class Solution(object):
    def productExceptSelf(self, nums):
       
     n = len(nums)
     answer = [1] * n

     left = 1
     right = 1
     for i in range(len(nums)):
         answer[i] = left
         left *= nums[i]
     for j in range(len(nums)-1,-1,-1):
         answer[j] *= right
         right *= nums[j]
    
     return answer    
        
