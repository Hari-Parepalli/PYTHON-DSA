class Solution(object):
    def isValid(self, s):
   
     stack = []
     for i in s:
        if i == '(' or i =='[' or i =='{':
            stack.append(i)
        else:        
            if not stack:
                return False
                break
        
            top = stack[-1]
            if i == ')' and top == '(':
                stack.pop()
            elif i ==']' and top == '[':
                stack.pop()
            elif i == '}' and top =='{':
                stack.pop()
            else:
                return False
                break
             
     else:
        if not stack:
           return True
        else:
           return False
            
        
